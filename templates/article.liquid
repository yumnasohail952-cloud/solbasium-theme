<div class="wrap" style="padding:80px 40px">
  <div style="max-width:760px;margin:0 auto">
    {%- if article.image -%}
      <div style="aspect-ratio:16/9;overflow:hidden;border-radius:2px;margin-bottom:48px">
        <img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.image.alt | default: article.title | escape }}"
             style="width:100%;height:100%;object-fit:cover" width="1400" height="788" loading="eager">
      </div>
    {%- endif -%}
    <div class="eyebrow" style="margin-bottom:16px">— {{ blog.title }} · {{ article.published_at | date: '%B %d, %Y' }}</div>
    <h1 style="font-size:clamp(36px,4.5vw,68px);margin-bottom:32px">{{ article.title }}</h1>
    <div style="font-size:17px;line-height:1.75;color:var(--ink);max-width:65ch">
      {{ article.content }}
    </div>
    <div style="margin-top:64px;padding-top:32px;border-top:1px solid var(--line-2)">
      <a href="{{ blog.url }}" class="btn ghost">← All articles</a>
    </div>
  </div>
</div>
