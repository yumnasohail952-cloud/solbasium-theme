<div class="wrap" style="padding:80px 40px">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start">
    <div style="position:relative;aspect-ratio:4/5;background:var(--gray);border-radius:2px;overflow:hidden">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 1200 }}"
             alt="{{ product.featured_image.alt | default: product.title | escape }}"
             style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover">
      {%- endif -%}
    </div>
    <div style="padding-top:24px">
      <div class="eyebrow" style="margin-bottom:16px">— {{ product.type }}</div>
      <h1 style="font-size:clamp(36px,4vw,64px)">{{ product.title }}</h1>
      <div style="margin-top:24px;font-size:28px;font-weight:700;letter-spacing:-.01em">
        {%- if product.compare_at_price > product.price -%}
          <span style="text-decoration:line-through;color:var(--ink-3);font-size:18px;margin-right:10px">{{ product.compare_at_price | money }}</span>
          <span style="color:var(--orange)">{{ product.price | money }}</span>
        {%- else -%}
          {{ product.price | money }}
        {%- endif -%}
      </div>
      <div style="margin-top:24px;font-size:16px;line-height:1.65;color:var(--ink-2);max-width:52ch">
        {{ product.description }}
      </div>
      {%- form 'product', product -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <div style="margin-top:40px;display:flex;gap:14px;flex-wrap:wrap">
          <button type="submit" class="btn primary" {%- unless product.available %} disabled{%- endunless -%}>
            {%- if product.available -%}Add to bag <span class="arrow"></span>{%- else -%}Sold out{%- endif -%}
          </button>
          <a href="#contact" class="btn ghost">Talk to an expert</a>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>
