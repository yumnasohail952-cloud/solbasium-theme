<div class="wrap" style="padding:80px 40px">
  <div style="margin-bottom:48px">
    <div class="eyebrow" style="margin-bottom:16px">— Collection</div>
    <h1 style="font-size:clamp(48px,6vw,92px)">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p style="margin-top:18px;color:var(--ink-2);font-size:17px;max-width:52ch;line-height:1.55">{{ collection.description }}</p>
    {%- endif -%}
  </div>
  <div class="pgrid">
    {%- for product in collection.products -%}
      {%- render 'product-card', product: product -%}
    {%- endfor -%}
  </div>
  {%- if paginate.pages > 1 -%}
    <div style="margin-top:64px;text-align:center">
      {{ paginate | default_pagination }}
    </div>
  {%- endif -%}
</div>
