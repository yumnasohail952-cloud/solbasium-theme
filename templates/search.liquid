<div class="wrap" style="padding:80px 40px">
  <div class="eyebrow" style="margin-bottom:24px">— Search</div>
  <h1 style="font-size:clamp(40px,5vw,72px);margin-bottom:40px">Search <span class="it">results.</span></h1>
  {%- form 'search' -%}
    <div style="display:flex;gap:0;max-width:640px;border-bottom:1px solid var(--ink);padding-bottom:8px;margin-bottom:64px">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="What are you looking for?"
             style="flex:1;background:transparent;border:0;font-size:20px;font-family:var(--sans);padding:8px 0;outline:none;letter-spacing:.01em">
      <button type="submit" class="btn dark" style="padding:10px 18px">Search <span class="arrow"></span></button>
    </div>
  {%- endform -%}
  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p style="color:var(--ink-2);font-size:17px">No results for "{{ search.terms }}".</p>
    {%- else -%}
      <p style="color:var(--ink-3);font-size:13px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:40px">{{ search.results_count }} results</p>
      <div class="pgrid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {%- render 'product-card', product: item -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div>
