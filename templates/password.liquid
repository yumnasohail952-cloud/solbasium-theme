<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <style>
    body { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: var(--ink); color: var(--cream); }
    .pw { text-align: center; max-width: 480px; padding: 40px; }
    .pw h1 { font-size: clamp(48px, 8vw, 96px); color: var(--cream); margin-bottom: 16px; }
    .pw p { color: #F2ECE0AA; font-size: 16px; margin-bottom: 40px; }
    .pw input { background: transparent; border: 0; border-bottom: 1px solid #F2ECE044; color: var(--cream); font-family: var(--sans); font-size: 16px; padding: 12px 4px; outline: none; width: 100%; margin-bottom: 24px; }
    .pw input::placeholder { color: #F2ECE055; }
  </style>
</head>
<body>
  <div class="pw">
    <div style="width:32px;height:32px;border-radius:50%;background:radial-gradient(circle at 35% 35%, #F04A20 0%, #66379D 80%);margin:0 auto 24px"></div>
    <h1>Solbasium<span class="it">.</span></h1>
    <p>Something new is coming. Enter the password to get early access.</p>
    {%- form 'storefront_password' -%}
      {{ form.errors | default_errors }}
      <input type="password" name="password" placeholder="Password" autocomplete="current-password">
      <button type="submit" class="btn primary" style="width:100%;justify-content:center">Enter <span class="arrow"></span></button>
    {%- endform -%}
  </div>
</body>
</html>
