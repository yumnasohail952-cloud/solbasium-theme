    <div class="top">
      <div>
        <div class="logo">
          <span class="mark"></span>
          <span>{{ shop.name }}</span>
        </div>
        <p class="tag">Relentless Innovation. Engineered for the people who refuse to settle.</p>
      </div>
      <div class="col">
        <h5>Shop</h5>
        <ul>
          <li><a href="/products/helios-commercial">Helios Commercial™</a></li>
          <li><a href="/products/nova-red-light-therapy-bed">Nova Bed</a></li>
          <li><a href="/products/flex-red-light-therapy-bed">Flex Bed</a></li>
          <li><a href="/products/quantum-roller">Quantum Roller</a></li>
          <li><a href="/products/s2-massage-gun">S2 Massage Gun</a></li>
          <li><a href="/collections/optix-pads">Optix Pads</a></li>
          <li><a href="/products/clear-pemf-mat">Clear PEMF Mat</a></li>
          <li><a href="/products/solbasium-bright">Solbasium Bright</a></li>
