{%- comment -%}
  Renders a product card in the shop grid.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

<a class="pcard" href="{{ product.url }}">
  <div class="img">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 800 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="800"
        height="1000"
        loading="lazy">
    {%- endif -%}

    {%- assign badge_tag = '' -%}
    {%- assign badge_class = '' -%}
    {%- for tag in product.tags -%}
      {%- if tag == 'flagship' -%}{%- assign badge_tag = 'Flagship' -%}{%- assign badge_class = '' -%}
      {%- elsif tag == 'new' -%}{%- assign badge_tag = 'New' -%}{%- assign badge_class = '' -%}
      {%- elsif tag == 'pre-order' -%}{%- assign badge_tag = 'Pre-order' -%}{%- assign badge_class = ' purple' -%}
      {%- elsif tag == 'patent-pending' -%}{%- assign badge_tag = 'Patent Pending' -%}{%- assign badge_class = ' purple' -%}
      {%- elsif tag == 'wearable' -%}{%- assign badge_tag = 'Wearable' -%}{%- assign badge_class = ' alt' -%}
      {%- elsif tag == 'available' -%}{%- assign badge_tag = 'Available' -%}{%- assign badge_class = ' alt' -%}
      {%- elsif tag == 'hand-held' -%}{%- assign badge_tag = 'Hand-held' -%}{%- assign badge_class = ' alt' -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if product.compare_at_price > product.price -%}
      {%- assign badge_tag = '−' | append: product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round | append: '%' -%}
      {%- assign badge_class = ' sale' -%}
    {%- endif -%}

    {%- if badge_tag != '' -%}
      <span class="badge{{ badge_class }}">{{ badge_tag }}</span>
    {%- endif -%}
    <span class="quick">Quick view →</span>
  </div>

  <div class="meta">
    <div>
      <div class="name">{{ product.title }}</div>
      {%- if product.tags.size > 0 -%}
        <div class="tags">
          {%- for tag in product.tags limit: 3 -%}
            {%- unless tag == 'flagship' or tag == 'new' or tag == 'pre-order' or tag == 'wearable' or tag == 'available' or tag == 'patent-pending' or tag == 'hand-held' -%}
              <span>{{ tag }}</span>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
    <div class="price">
      {%- if product.compare_at_price > product.price -%}
        <span class="was">{{ product.compare_at_price | money }}</span>
        <span class="sale-price">{{ product.price | money }}</span>
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </div>
  </div>

  {%- if product.description != blank -%}
    <p class="desc">{{ product.description | strip_html | truncate: 100 }}</p>
  {%- endif -%}
</a>
