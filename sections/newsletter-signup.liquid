<section class="news">
  <div class="wrap">
    <div class="eyebrow">— {{ section.settings.eyebrow }}</div>
    <h3>{{ section.settings.heading_line1 }}, <span class="it">{{ section.settings.heading_line2 }}</span></h3>
    <p class="sub">{{ section.settings.subtext }}</p>
    {%- form 'customer', id: 'NewsletterForm', class: 'news' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="sub" style="color:var(--orange);margin-top:24px">Subscribed ✓</p>
      {%- else -%}
        <input
          type="email"
          name="contact[email]"
          value="{{ form.email }}"
          placeholder="{{ section.settings.placeholder }}"
          autocomplete="email"
          required>
        <button type="submit">
          {{ section.settings.button_label }} <span class="arrow" style="display:inline-block"></span>
        </button>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Signup",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Dispatch · Monthly"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "New drops"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2 (italic serif)",
      "default": "in your inbox."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Sign up for exclusive offers and new product drops. No marketing detritus — just the work."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@address.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [{ "name": "Newsletter Signup" }]
}
{% endschema %}
